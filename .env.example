# GitHub Personal Access Token for Backstage integrations (repo, read:org, read:user scopes)
GITHUB_TOKEN=

# GitHub OAuth App credentials for sign-in
# Create at: GitHub > Settings > Developer settings > OAuth Apps
# Homepage URL: http://localhost:3000
# Authorization callback URL: http://localhost:7007/api/auth/github/handler/frame
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# AWS credentials (only needed for deploying scaffolded services to ECS)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
